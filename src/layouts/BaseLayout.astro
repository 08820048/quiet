---
import '../styles/global.css';

const { title, description, bodyClass } = Astro.props;
const siteTitle = title ?? 'Minimal Markdown Blog';
const siteDescription = description ?? 'A minimal technical blog powered by Markdown.';
const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://example.com');
---

<!doctype html>
<html lang="en-US" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{siteTitle}</title>
    <meta name="description" content={siteDescription} />
    <link rel="canonical" href={canonical.toString()} />
    <script is:inline>
      (() => {
        const savedTheme = localStorage.getItem('theme');
        const systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const theme = savedTheme === 'light' || savedTheme === 'dark'
          ? savedTheme
          : (systemDark ? 'dark' : 'light');
        document.documentElement.dataset.theme = theme;
      })();
    </script>
  </head>
  <body class={bodyClass}>
    <header class="site-header">
      <nav class="site-nav">
        <a href="/">Home</a>
        <a href="/projects">Products</a>
        <a href="/links">Links</a>
        <div class="site-controls">
          <button
            id="theme-toggle"
            class="theme-toggle"
            type="button"
            aria-label="Toggle dark mode"
            title="Toggle dark mode"
          >dark</button>
        </div>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <script is:inline>
      (() => {
        const themeToggle = document.getElementById('theme-toggle');

        const applyTheme = (theme) => {
          const resolvedTheme = theme === 'dark' ? 'dark' : 'light';
          document.documentElement.dataset.theme = resolvedTheme;
          localStorage.setItem('theme', resolvedTheme);
          if (themeToggle) {
            themeToggle.textContent = resolvedTheme === 'dark' ? 'light' : 'dark';
          }
        };

        applyTheme(document.documentElement.dataset.theme);

        if (themeToggle) {
          themeToggle.addEventListener('click', () => {
            const nextTheme = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
            applyTheme(nextTheme);
          });
        }
      })();
    </script>
  </body>
</html>
