---
import '../styles/global.css';
import mermaidClientUrl from '../client/mermaid-client.js?url';
import siteUiClientUrl from '../client/site-ui.js?url';
import {
  DEFAULT_OG_IMAGE_PATH,
  NAV_ITEMS,
  SEARCH_PLACEHOLDER,
  SITE_AUTHOR,
  SITE_DESCRIPTION,
  SITE_LOCALE,
  SITE_NAME,
  SITE_OG_LOCALE,
  getAbsoluteUrl,
  getSiteOrigin,
} from '../utils/site.js';

const {
  title,
  description,
  bodyClass = '',
  showSearch = false,
  enableMermaid = false,
  seoType = 'website',
  publishedTime,
  modifiedTime,
  keywords = [],
  imagePath = DEFAULT_OG_IMAGE_PATH,
  schema,
} = Astro.props;

const siteOrigin = getSiteOrigin(Astro.site);
const browserTitle = 'QUIET';
const siteTitle = title ? `${title} | ${SITE_NAME}` : SITE_NAME;
const siteDescription = description ?? SITE_DESCRIPTION;
const canonical = getAbsoluteUrl(Astro.url.pathname, siteOrigin);
const ogImage = getAbsoluteUrl(imagePath, siteOrigin);
const resolvedKeywords = Array.isArray(keywords)
  ? keywords.map((keyword) => String(keyword).trim()).filter(Boolean)
  : [];
const pathname = Astro.url.pathname;

const defaultSchema =
  seoType === 'article'
    ? {
        '@context': 'https://schema.org',
        '@type': 'Article',
        headline: title ?? SITE_NAME,
        description: siteDescription,
        url: canonical.toString(),
        image: ogImage.toString(),
        inLanguage: SITE_LOCALE,
        author: {
          '@type': 'Person',
          name: SITE_AUTHOR.name,
          url: SITE_AUTHOR.url,
        },
        publisher: {
          '@type': 'Person',
          name: SITE_AUTHOR.name,
          url: SITE_AUTHOR.url,
        },
        datePublished: publishedTime,
        dateModified: modifiedTime ?? publishedTime,
        keywords: resolvedKeywords.join(', ') || undefined,
      }
    : {
        '@context': 'https://schema.org',
        '@type': 'WebSite',
        name: SITE_NAME,
        description: SITE_DESCRIPTION,
        url: siteOrigin.toString(),
        inLanguage: SITE_LOCALE,
        potentialAction: {
          '@type': 'SearchAction',
          target: `${siteOrigin.toString().replace(/\/$/, '')}/search?q={search_term_string}`,
          'query-input': 'required name=search_term_string',
        },
      };
const headSchema = schema ?? defaultSchema;
---

<!doctype html>
<html lang={SITE_LOCALE} data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{browserTitle}</title>
    <meta name="description" content={siteDescription} />
    <meta name="robots" content="index,follow,max-image-preview:large" />
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#ffffff" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#000000" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="canonical" href={canonical.toString()} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${SITE_NAME} RSS`}
      href={getAbsoluteUrl('/rss.xml', siteOrigin).toString()}
    />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:locale" content={SITE_OG_LOCALE} />
    <meta property="og:type" content={seoType === 'article' ? 'article' : 'website'} />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={siteDescription} />
    <meta property="og:url" content={canonical.toString()} />
    <meta property="og:image" content={ogImage.toString()} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={siteTitle} />
    <meta name="twitter:description" content={siteDescription} />
    <meta name="twitter:image" content={ogImage.toString()} />
    {resolvedKeywords.length > 0 && (
      <meta name="keywords" content={resolvedKeywords.join(', ')} />
    )}
    {seoType === 'article' && publishedTime && (
      <meta property="article:published_time" content={publishedTime} />
    )}
    {seoType === 'article' && modifiedTime && (
      <meta property="article:modified_time" content={modifiedTime} />
    )}
    {resolvedKeywords.map((keyword) => (
      <meta property="article:tag" content={keyword} />
    ))}
    <script is:inline type="application/ld+json" set:html={JSON.stringify(headSchema)} />
    <script
      is:inline
      defer
      src="https://cloud.umami.is/script.js"
      data-website-id="66b435e0-5ca6-4001-9716-7faa4760ca9d"
    ></script>
    <script is:inline>
      (() => {
        const savedTheme = localStorage.getItem('theme');
        const systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const theme = savedTheme === 'light' || savedTheme === 'dark'
          ? savedTheme
          : (systemDark ? 'dark' : 'light');
        document.documentElement.dataset.theme = theme;
      })();
    </script>

    <script is:inline type="module" src={siteUiClientUrl}></script>
    <script is:inline>
      (async () => {
        const el = document.getElementById('umami-views');
        if (!el) return;
        const SHARE_ID = 'Xi4CTmCjARCsOIEV';
        const API_BASE = 'https://cloud.umami.is/analytics/us/api';
        try {
          const shareRes = await fetch(`${API_BASE}/share/${SHARE_ID}`);
          if (!shareRes.ok) return;
          const { token, websiteId } = await shareRes.json();
          if (!token || !websiteId) return;
          const endAt = Date.now();
          const statsRes = await fetch(
            `${API_BASE}/websites/${websiteId}/stats?startAt=0&endAt=${endAt}`,
            {
              headers: {
                'x-umami-share-token': token,
                'x-umami-share-context': '1',
              },
            }
          );
          if (!statsRes.ok) return;
          const data = await statsRes.json();
          const views = typeof data?.pageviews === 'number'
            ? data.pageviews
            : data?.pageviews?.value;
          if (typeof views === 'number') {
            el.textContent = ` · Views ${views.toLocaleString()}`;
          }
        } catch (_) {
          /* silently ignore */
        }
      })();
    </script>
    {enableMermaid && <script is:inline type="module" src={mermaidClientUrl}></script>}
  </head>
  <body class={bodyClass}>
    <header class="site-header">
      <nav class="site-nav">
        <a class="site-brand" href="/">Quiet</a>
        <div class="site-nav-links">
          {NAV_ITEMS.map((item) => {
            const isActive =
              item.href === '/'
                ? pathname === '/'
                : item.href.endsWith('.xml')
                  ? pathname === item.href
                  : pathname === item.href || pathname.startsWith(`${item.href}/`);

            return (
              <a class:list={['site-nav-link', { 'is-active': isActive }]} href={item.href}>
                {item.label}
              </a>
            );
          })}
        </div>
        {showSearch && (
          <div class="site-search">
            <span class="site-search-shortcut" aria-hidden="true">/</span>
            <input
              id="header-search"
              type="search"
              class="site-search-input"
              placeholder={SEARCH_PLACEHOLDER}
              aria-label={SEARCH_PLACEHOLDER}
            />
          </div>
        )}
        <div class="site-controls">
          <button
            id="theme-toggle"
            class="theme-toggle"
            type="button"
            aria-label="Toggle dark mode"
            title="Toggle dark mode"
          >dark</button>
        </div>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="site-footer-content">
        <p>© 2026 Quiet. Built by XuYi.<span id="umami-views" class="site-stats" aria-live="polite"></span></p>
        <div class="site-social-links" aria-label="Social links">
          <a
            class="site-social-link"
            href="https://x.com/xuyixff"
            target="_blank"
            rel="noreferrer"
            aria-label="X"
            title="X"
          >
            <svg viewBox="0 0 16 16" aria-hidden="true">
              <path fill="currentColor" d="M9.294 6.928 14.357 1h-1.2L8.761 6.147 5.24 1H1.189l5.31 7.76L1.189 15h1.2l4.643-5.436L10.76 15h4.051zM7.64 8.866l-.538-.774L2.82 1.926h1.844l3.457 4.967.538.774 4.494 6.46h-1.844z"/>
            </svg>
          </a>
          <a
            class="site-social-link"
            href="https://github.com/08820048"
            target="_blank"
            rel="noreferrer"
            aria-label="GitHub"
            title="GitHub"
          >
            <svg viewBox="0 0 16 16" aria-hidden="true">
              <path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8a8.01 8.01 0 0 0 5.47 7.59c.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.5-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.52 7.52 0 0 1 4 0c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8"/>
            </svg>
          </a>
        </div>
      </div>
    </footer>
    <div id="theme-transition-wordmark" class="theme-transition-wordmark" aria-hidden="true" hidden>
      <span class="theme-transition-wordmark-text">QUIET</span>
    </div>
    <button
      id="back-to-top"
      class="back-to-top"
      type="button"
      aria-label="Back to top"
      title="Back to top"
    >Top</button>
    <div
      id="image-viewer"
      class="image-viewer"
      role="dialog"
      aria-modal="true"
      aria-label="Image preview"
      aria-hidden="true"
      hidden
    >
      <button
        id="image-viewer-close"
        class="image-viewer-close"
        type="button"
        aria-label="Close image preview"
        title="Close image preview"
      >Close</button>
      <figure class="image-viewer-frame">
        <img id="image-viewer-image" class="image-viewer-image" alt="" />
        <figcaption id="image-viewer-caption" class="image-viewer-caption" hidden></figcaption>
      </figure>
    </div>
  </body>
</html>
