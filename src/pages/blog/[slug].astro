---
import BaseLayout from '../../layouts/BaseLayout.astro';
import path from 'node:path';
import { stat } from 'node:fs/promises';

type PostModule = {
  file: string;
  frontmatter?: Record<string, unknown>;
  rawContent: () => Promise<string>;
  Content: any;
};

/** Build static routes and attach neighboring posts. */
export async function getStaticPaths() {
  const modules = import.meta.glob('../../content/blog/*.md') as Record<string, () => Promise<PostModule>>;

  const posts = await Promise.all(
    Object.entries(modules).map(async ([filePath, loader]) => {
      const mod = await loader();
      const fileStat = await stat(mod.file);
      const raw = await mod.rawContent();
      const frontmatter =
        mod.frontmatter && typeof mod.frontmatter === 'object' ? mod.frontmatter : {};
      const fileName = path.basename(filePath, path.extname(filePath));
      const titleFromContent = raw
        .split('\n')
        .map((line) => line.trim())
        .find((line) => line.startsWith('# '))
        ?.replace(/^#\s+/, '');
      const title =
        (typeof frontmatter.title === 'string' ? frontmatter.title : undefined) ??
        titleFromContent ??
        fileName;

      const dateValue =
        frontmatter.date instanceof Date
          ? frontmatter.date
          : frontmatter.date
            ? new Date(String(frontmatter.date))
            : fileStat.mtime;

      const slug = fileName.toLowerCase().replace(/[^a-z0-9\u4e00-\u9fa5]+/g, '-') || fileName;

      return {
        filePath,
        title,
        dateValue,
        slug,
        url: `/blog/${slug}`,
      };
    })
  );

  const sortedPosts = posts.sort((a, b) => b.dateValue.valueOf() - a.dateValue.valueOf());

  return sortedPosts.map((post, index) => {
    const previousPost = index > 0 ? sortedPosts[index - 1] : null;
    const nextPost = index < sortedPosts.length - 1 ? sortedPosts[index + 1] : null;

    return {
      params: { slug: post.slug },
      props: {
        filePath: post.filePath,
        title: post.title,
        dateISO: post.dateValue.toISOString(),
        previousPost: previousPost ? { title: previousPost.title, url: previousPost.url } : null,
        nextPost: nextPost ? { title: nextPost.title, url: nextPost.url } : null,
      },
    };
  });
}

const modules = import.meta.glob('../../content/blog/*.md') as Record<string, () => Promise<PostModule>>;

const { filePath, title, dateISO, previousPost, nextPost } = Astro.props;
const loader = modules[filePath];
if (!loader) {
  throw new Error(`Post module not found for path: ${filePath}`);
}

const mod = await loader();
const Content = mod.Content;
const publishedDate = new Date(dateISO).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<BaseLayout title={title} description={title} bodyClass="post-detail-page">
  <article class="post post-detail">
    <h1>{title}</h1>
    <div class="post-meta">
      <span>Published</span>
      {' '}
      <span>{publishedDate}</span>
    </div>
    <div class="post-content">
      <Content />
    </div>

    {(previousPost || nextPost) && (
      <nav class="post-pagination" aria-label="Post navigation">
        <div class="post-pagination-item post-pagination-prev">
          {previousPost && (
            <a href={previousPost.url} title={previousPost.title}>
              {previousPost.title}
            </a>
          )}
        </div>
        <div class="post-pagination-item post-pagination-next">
          {nextPost && (
            <a href={nextPost.url} title={nextPost.title}>
              {nextPost.title}
            </a>
          )}
        </div>
      </nav>
    )}
  </article>
</BaseLayout>
