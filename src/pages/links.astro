---
import BaseLayout from '../layouts/BaseLayout.astro';

const linksModule = await import('../content/pages/links.md');
const LinksContent = linksModule.Content;
const frontmatter =
  linksModule.frontmatter && typeof linksModule.frontmatter === 'object'
    ? linksModule.frontmatter
    : {};
const pageTitle =
  typeof frontmatter.title === 'string'
    ? frontmatter.title
    : 'Links - Minimal Markdown Blog';
const pageDescription =
  typeof frontmatter.description === 'string'
    ? frontmatter.description
    : 'Useful links.';
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <section class="page-section">
    <LinksContent />
  </section>
</BaseLayout>
