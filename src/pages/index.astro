---
import BaseLayout from '../layouts/BaseLayout.astro';
import InfinitePostList from '../components/InfinitePostList.jsx';
import path from 'node:path';
import { resolvePostSlug } from '../utils/slug.js';
import { formatUtcDate, resolvePostMetadata } from '../utils/postMetadata.js';

const modules = import.meta.glob('../content/blog/*.md', { eager: true }) as Record<
  string,
  {
    file: string;
    frontmatter?: Record<string, unknown>;
    rawContent: () => Promise<string>;
    compiledContent: () => Promise<string>;
  }
>;

const posts = await Promise.all(
  Object.values(modules).map(async (mod) => {
    const filePath = mod.file;
    const raw = await mod.rawContent();
    const frontmatter = (mod.frontmatter ?? {}) as Record<string, unknown>;
    const fileName = path.basename(filePath, path.extname(filePath));
    const { title, updatedAt, sortDate } = resolvePostMetadata(raw, frontmatter, fileName);
    const slug = resolvePostSlug(fileName);
    const listDate = updatedAt ?? sortDate;

    return {
      id: fileName,
      title,
      dateValue: sortDate?.valueOf() ?? 0,
      updatedAtISO: listDate?.toISOString() ?? '',
      updatedAtLabel: formatUtcDate(listDate),
      url: `/blog/${slug}`,
    };
  })
);

const sorted = posts.sort((a, b) => b.dateValue - a.dateValue);
---

<BaseLayout
  title="Hi,Im XuYi, this is my blog."
  description="A minimal technical blog."
  bodyClass="home-page"
>
  <section class="intro">
    <h1 class="intro-title">Hi,Im XuYi, this is my blog.</h1>
    <p class="intro-text">
      Indie dev | Rust fan | Built Welight:
      <a href="https://waer.ltd" target="_blank" rel="noreferrer">https://waer.ltd</a>
    </p>
    <p class="intro-text">
      and a lightweight Markdown editor for technical writing →
      <a href="https://ornata.app" target="_blank" rel="noreferrer">https://ornata.app</a>
    </p>
  </section>
  <h2 class="page-title">Latest Posts</h2>
  <InfinitePostList posts={sorted} client:load />
</BaseLayout>
