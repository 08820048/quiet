---
import BaseLayout from '../layouts/BaseLayout.astro';
import InfinitePostList from '../components/InfinitePostList.jsx';
import path from 'node:path';
import { stat } from 'node:fs/promises';

const modules = import.meta.glob('../content/blog/*.md', { eager: true }) as Record<
  string,
  {
    file: string;
    frontmatter?: Record<string, unknown>;
    rawContent: () => Promise<string>;
    compiledContent: () => Promise<string>;
  }
>;

/** 生成文章标题 */
const resolveTitle = (raw: string, frontmatter: Record<string, unknown>, fileName: string) => {
  const titleFromContent = raw
    .split('\n')
    .map((line: string) => line.trim())
    .find((line: string) => line.startsWith('# '))
    ?.replace(/^#\s+/, '');

  return (
    (typeof frontmatter.title === 'string' ? frontmatter.title : undefined) ??
    titleFromContent ??
    fileName
  );
};

/** 生成文章发布日期 */
const resolveDate = (frontmatter: Record<string, unknown>, fallback: Date) => {
  if (frontmatter.date instanceof Date) {
    return frontmatter.date;
  }
  if (frontmatter.date) {
    return new Date(String(frontmatter.date));
  }
  return fallback;
};

/** 生成文章 slug */
const resolveSlug = (fileName: string) => {
  const slug = fileName.toLowerCase().replace(/[^a-z0-9\u4e00-\u9fa5]+/g, '-');
  return slug || fileName;
};

const posts = await Promise.all(
  Object.values(modules).map(async (mod) => {
    const filePath = mod.file;
    const fileStat = await stat(filePath);
    const raw = await mod.rawContent();
    const frontmatter = (mod.frontmatter ?? {}) as Record<string, unknown>;
    const fileName = path.basename(filePath, path.extname(filePath));
    const title = resolveTitle(raw, frontmatter, fileName);
    const dateValue = resolveDate(frontmatter, fileStat.mtime);
    const slug = resolveSlug(fileName);

    return {
      id: fileName,
      title,
      date: dateValue.toLocaleDateString('zh-CN'),
      dateValue,
      url: `/blog/${slug}`,
    };
  })
);

const sorted = posts.sort((a, b) => b.dateValue.valueOf() - a.dateValue.valueOf());
---

<BaseLayout title="极简 Markdown 博客" description="一个极简的 Markdown 技术博客">
  <section class="intro">
    <h1 class="intro-title">你好，我是你的极简博客。</h1>
    <p class="intro-text">这里记录技术、想法与实践，保持简洁与专注。</p>
    <p class="intro-text">文章以 Markdown 编写，点击标题进入详情阅读。</p>
  </section>
  <h2 class="page-title">最新文章</h2>
  <InfinitePostList posts={sorted} client:load />
</BaseLayout>
