---
import BaseLayout from '../layouts/BaseLayout.astro';
import InfinitePostList from '../components/InfinitePostList.jsx';
import { formatUtcDate } from '../utils/postMetadata.js';
import { getAllPosts, getTagEntries } from '../utils/posts.js';
import { SITE_DESCRIPTION } from '../utils/site.js';

const [posts, tagEntries] = await Promise.all([getAllPosts(), getTagEntries()]);

const sorted = posts.map((post) => {
  const listDate = post.updatedAt ?? post.publishedAt ?? post.sortDate;
  return {
    id: post.id,
    title: post.title,
    url: post.url,
    category: post.category,
    tags: post.tags,
    description: post.description,
    readingMinutes: post.readingMinutes,
    searchText: post.searchText,
    dateValue: post.sortValue,
    updatedAtISO: listDate?.toISOString() ?? '',
    updatedAtLabel: formatUtcDate(listDate),
  };
});
---

<BaseLayout
  title="Minimal, fast, geeky developer notes"
  description={SITE_DESCRIPTION}
  bodyClass="home-page has-search"
  showSearch={true}
>
  <section class="intro">
    <p class="eyebrow">Quiet</p>
    <h1 class="intro-title">Minimal, fast, geeky developer notes.</h1>
    <p class="intro-text">
      Indie dev, Rust fan, and tool builder. Shipping Welight:
      <a href="https://waer.ltd" target="_blank" rel="noreferrer">https://waer.ltd</a>
    </p>
    <p class="intro-text">
      plus Ornata, a lightweight Markdown editor for technical writing →
      <a href="https://ornata.app" target="_blank" rel="noreferrer">https://ornata.app</a>
    </p>
    <div class="home-stats" aria-label="Site stats">
      <span class="meta-chip">{sorted.length} posts</span>
      <span class="meta-chip">{tagEntries.length} tags</span>
      <a class="meta-chip meta-chip-link" href="/archive">Archive</a>
      <a class="meta-chip meta-chip-link" href="/tags">Tags</a>
      <a class="meta-chip meta-chip-link" href="/rss.xml">RSS</a>
    </div>
  </section>
  <h2 class="page-title">Latest Posts</h2>
  <InfinitePostList posts={sorted} showPreview={true} client:load />
</BaseLayout>
