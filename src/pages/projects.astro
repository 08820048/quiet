---
import BaseLayout from '../layouts/BaseLayout.astro';

const projectsModule = await import('../content/pages/projects.md');
const ProjectsContent = projectsModule.Content;
const frontmatter =
  projectsModule.frontmatter && typeof projectsModule.frontmatter === 'object'
    ? projectsModule.frontmatter
    : {};
const pageTitle =
  typeof frontmatter.title === 'string'
    ? frontmatter.title
    : 'Products - Minimal Markdown Blog';
const pageDescription =
  typeof frontmatter.description === 'string'
    ? frontmatter.description
    : 'Personal products and tools.';
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <section class="page-section">
    <ProjectsContent />
  </section>
</BaseLayout>
