---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostDirectory from '../components/PostDirectory.astro';
import { getArchiveGroups, getTagEntries } from '../utils/posts.js';

const [archiveGroups, tagEntries] = await Promise.all([getArchiveGroups(), getTagEntries()]);
const postCount = archiveGroups.reduce((count, group) => count + group.posts.length, 0);
---

<BaseLayout
  title="Archive"
  description="Browse every post by year, with tag shortcuts for fast navigation."
  bodyClass="archive-page"
>
  <section class="archive-hero">
    <p class="eyebrow">Archive</p>
    <h1 class="page-title">All posts, sorted for fast scanning.</h1>
    <p class="intro-text">
      {postCount}
      {' '}
      posts across
      {' '}
      {archiveGroups.length}
      {' '}
      years. Jump by tag or scroll the full timeline.
    </p>
    <div class="tag-cloud">
      {tagEntries.slice(0, 12).map((tag) => (
        <a class="meta-chip meta-chip-link" href={`/tags/${tag.slug}`}>
          #{tag.name} · {tag.count}
        </a>
      ))}
    </div>
  </section>

  {archiveGroups.map((group) => (
    <section class="archive-year">
      <div class="archive-year-heading">
        <h2>{group.year}</h2>
        <span>{group.posts.length} posts</span>
      </div>
      <PostDirectory posts={group.posts} />
    </section>
  ))}
</BaseLayout>
